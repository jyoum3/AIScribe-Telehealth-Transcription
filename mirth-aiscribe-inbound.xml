          <script>// ===========================================================================
// STEP 1: Parse Raw Input Stream into a Native JavaScript Object
// Keeping Inbound Data Type as &quot;RAW&quot; allows JSON.parse() to create a clean primitive.
// ===========================================================================
var body = JSON.parse(connectorMessage.getRawData());
&#xd;
//SCHEDULE_FOLLOW Early Exit
//Scheduling payloads skip all HL7 building. Set channelMap flags for the JS Writer destination
//to pick up, then return early with a routing ACK.
if (body.type === &apos;SCHEDULE_FOLLOWUP&apos;) {
	channelMap.put(&apos;isScheduleFollowup&apos;, &apos;true&apos;);
	channelMap.put(&apos;scheduleCsn&apos;, String(body.newCsn));
	channelMap.put(&apos;scheduleMrn&apos;, String(body.mrn));
	channelMap.put(&apos;scheduleProviderId&apos;, String(body.providerId));
	channelMap.put(&apos;scheduleTargetDate&apos;, String(body.targetDate));

	var routingAck = JSON.stringify({
		status: &apos;ROUTING&apos;,
		type: &apos;SCHEDULE_FOLLOW&apos;,
		csn: String(body.newCsn)
	});
	responseMap.put(&apos;ackJson&apos;, new com.mirth.connect.userutil.Response(
		com.mirth.connect.userutil.Status.SENT,
		routingAck
		));
	logger.info(&apos;[aiscribe-inbound] SCHEDULE_FOLLOW routing - newCsn:&apos; + body.newCsn);
	return; //Skip all HL7 building below
}

channelMap.put(&apos;isScheduleFollowup&apos;, &apos;false&apos;);

&#xd;
// ===========================================================================
// STEP 2: Dynamic Amendment Routing &amp; Segment Overrides 
// version_num absent or 1 = initial note -&gt; MDM^T02, docStatus AU (Authenticated)
// version_num &gt; 1          = amendment   -&gt; MDM^T04, docStatus LA (Legally Authenticated)
// ===========================================================================
var versionNum  = body.version_num ? parseInt(String(body.version_num)) : 1;
var isAmendment = (versionNum &gt; 1);
var docStatus   = isAmendment ? &apos;LA&apos; : &apos;AU&apos;;

// MSH-9: Dynamically swap message triggers based on document version state
tmp[&apos;MSH&apos;][&apos;MSH.9&apos;][&apos;MSH.9.1&apos;] = &apos;MDM&apos;;
tmp[&apos;MSH&apos;][&apos;MSH.9&apos;][&apos;MSH.9.2&apos;] = isAmendment ? &apos;T04&apos; : &apos;T02&apos;;
tmp[&apos;MSH&apos;][&apos;MSH.9&apos;][&apos;MSH.9.3&apos;] = isAmendment ? &apos;MDM_T04&apos; : &apos;MDM_T02&apos;;

// TXA-8 &amp; TXA-17: Toggle completion and authentication states
tmp[&apos;TXA&apos;][&apos;TXA.8&apos;][&apos;TXA.8.1&apos;]   = docStatus;
tmp[&apos;TXA&apos;][&apos;TXA.17&apos;][&apos;TXA.17.1&apos;] = docStatus;

// ===========================================================================
// STEP 3: Populate the Channel Map for Destination Database Routing
// String() coercion prevents Rhino engine Java-to-JS object reference traps.
// ===========================================================================
channelMap.put(&apos;isAmendment&apos;,     isAmendment ? &apos;true&apos; : &apos;false&apos;);
channelMap.put(&apos;versionNum&apos;,      String(versionNum));
channelMap.put(&apos;amendmentReason&apos;, body.amendmentReason ? String(body.amendmentReason) : &apos;&apos;);
channelMap.put(&apos;authoredBy&apos;,      body.providerId      ? String(body.providerId)      : &apos;NULL&apos;);
channelMap.put(&apos;csn&apos;,             body.csn      ? String(body.csn)      : &apos;&apos;);
channelMap.put(&apos;noteText&apos;,        body.noteText ? String(body.noteText) : &apos;&apos;);

// ===========================================================================
// STEP 4: Standard HL7 v2 MDM Segment Mappings
// Maps strict 9-field contract variables into the outbound message template
// ===========================================================================

// MSH — Message Header (server-side timestamp + Java UUID message ID)
tmp[&apos;MSH&apos;][&apos;MSH.7&apos;][&apos;MSH.7.1&apos;]   = String(DateUtil.getCurrentDate(&apos;yyyyMMddHHmmss&apos;));
tmp[&apos;MSH&apos;][&apos;MSH.10&apos;][&apos;MSH.10.1&apos;] = String(java.util.UUID.randomUUID().toString());

// PID — Patient Demographics
// PID.3.1 = MRN, PID.3.4 = HOSPITAL
tmp[&apos;PID&apos;][&apos;PID.3&apos;][&apos;PID.3.1&apos;] = String(body.mrn);
tmp[&apos;PID&apos;][&apos;PID.3&apos;][&apos;PID.3.4&apos;] = &apos;HOSPITAL&apos;;
tmp[&apos;PID&apos;][&apos;PID.5&apos;][&apos;PID.5.1&apos;] = String(body.patientLastName);
tmp[&apos;PID&apos;][&apos;PID.5&apos;][&apos;PID.5.2&apos;] = String(body.patientFirstName);
// PID.7 must be YYYYMMDD — strip dashes from YYYY-MM-DD input
tmp[&apos;PID&apos;][&apos;PID.7&apos;][&apos;PID.7.1&apos;] = String(body.patientDob).replace(/-/g, &apos;&apos;);

// PV1 — Patient Visit / Encounter
// PV1.7 = provider_id^last^first
tmp[&apos;PV1&apos;][&apos;PV1.7&apos;][&apos;PV1.7.1&apos;]   = String(body.providerId);
tmp[&apos;PV1&apos;][&apos;PV1.7&apos;][&apos;PV1.7.2&apos;]   = String(body.providerLastName);
tmp[&apos;PV1&apos;][&apos;PV1.7&apos;][&apos;PV1.7.3&apos;]   = String(body.providerFirstName);
// PV1.19 = CSN (encounter/visit number)
tmp[&apos;PV1&apos;][&apos;PV1.19&apos;][&apos;PV1.19.1&apos;] = String(body.csn);
// PV1.44 = visit timestamp (server time at moment of submission)
tmp[&apos;PV1&apos;][&apos;PV1.44&apos;][&apos;PV1.44.1&apos;] = String(DateUtil.getCurrentDate(&apos;yyyyMMddHHmm&apos;));

// TXA — Document Header (author + document metadata)
tmp[&apos;TXA&apos;][&apos;TXA.4&apos;][&apos;TXA.4.1&apos;]   = String(DateUtil.getCurrentDate(&apos;yyyyMMddHHmmss&apos;));
tmp[&apos;TXA&apos;][&apos;TXA.11&apos;][&apos;TXA.11.1&apos;] = String(body.providerId);
tmp[&apos;TXA&apos;][&apos;TXA.16&apos;][&apos;TXA.16.1&apos;] = String(body.providerLastName);
tmp[&apos;TXA&apos;][&apos;TXA.16&apos;][&apos;TXA.16.2&apos;] = String(body.providerFirstName);

// OBX — Clinical Note Observation (the SOAP text payload)
tmp[&apos;OBX&apos;][&apos;OBX.3&apos;][&apos;OBX.3.1&apos;]   = &apos;MDM_TEXT&apos;;
tmp[&apos;OBX&apos;][&apos;OBX.3&apos;][&apos;OBX.3.2&apos;]   = &apos;Clinical Note Text&apos;;
var sanitizedNote = String(body.noteText).replace(/[\r\n]+/g, &apos; | &apos;);
tmp[&apos;OBX&apos;][&apos;OBX.5&apos;][&apos;OBX.5.1&apos;]   = sanitizedNote;
tmp[&apos;OBX&apos;][&apos;OBX.11&apos;][&apos;OBX.11.1&apos;] = &apos;F&apos;; // F = Finalized

// ===========================================================================
// STEP 5: Generate HL7 string + Build Synchronous HTTP ACK back to Express
// SerializerFactory converts the tmp XML structure into the HL7 pipe-delimited string.
// responseMap.put() is REQUIRED — it is what Mirth sends as the HTTP response body.
// ===========================================================================
var hl7String = SerializerFactory.getHL7Serializer(false, false, false).fromXML(tmp.toString());

var responseAck = JSON.stringify({
    status:    &apos;ACCEPTED&apos;,
    messageId: String(tmp[&apos;MSH&apos;][&apos;MSH.10&apos;][&apos;MSH.10.1&apos;]),
    csn:       String(body.csn),
    hl7:       hl7String
});

channelMap.put(&apos;ackJson&apos;, responseAck);
responseMap.put(&apos;ackJson&apos;, new com.mirth.connect.userutil.Response(
    com.mirth.connect.userutil.Status.SENT,
    responseAck
));

logger.info(&apos;[aiscribe-inbound] Transformer OK - CSN: &apos; + body.csn + &apos; Amendment: &apos; + isAmendment);</script>
