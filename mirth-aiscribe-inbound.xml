        <script>// ===========================================================================
// Schedule Follow-Up Writer — W16
// Inserts a future encounter into simulated_emr.encounters.
// Express generates the CSN; Mirth does the DB write.
// ===========================================================================
var dbConn;

try {
  dbConn = DatabaseConnectionFactory.createDatabaseConnection(
    &apos;org.postgresql.Driver&apos;,
    &apos;jdbc:postgresql://localhost:5432/simulated_emr&apos;,
    &apos;postgres&apos;,
    &apos;devpassword&apos;
  );

  var sql = &quot;INSERT INTO encounters (csn, mrn, provider_id, visit_date, visit_type) &quot; +
            &quot;VALUES (?, ?, ?, ?::timestamptz, &apos;Follow-up&apos;) ON CONFLICT (csn) DO NOTHING&quot;;

  dbConn.executeUpdate(sql, [
    channelMap.get(&apos;scheduleCsn&apos;),
    channelMap.get(&apos;scheduleMrn&apos;),
    parseInt(channelMap.get(&apos;scheduleProviderId&apos;)),
    channelMap.get(&apos;scheduleTargetDate&apos;)
  ]);

  // Overwrite the preliminary transformer ACK with the confirmed success ACK
  var successAck = JSON.stringify({
    status: &apos;ACCEPTED&apos;,
    type:   &apos;SCHEDULE_FOLLOWUP&apos;,
    csn:    channelMap.get(&apos;scheduleCsn&apos;)
  });
  responseMap.put(&apos;ackJson&apos;, new com.mirth.connect.userutil.Response(
    com.mirth.connect.userutil.Status.SENT,
    successAck
  ));

  logger.info(&apos;[aiscribe-inbound] Follow-up encounter written — CSN: &apos; + channelMap.get(&apos;scheduleCsn&apos;));

} catch (e) {
  logger.error(&apos;[aiscribe-inbound] SCHEDULE_FOLLOWUP DB write failed: &apos; + e.message);
  throw e; // Forces Mirth to mark message as Errored on dashboard

} finally {
  if (dbConn) {
    dbConn.close();
  }
}
</script>
