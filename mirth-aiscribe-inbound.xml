        <query>// ===========================================================================
// STEP 1: Extract Variables from Channel Map &amp; Enforce Null-Safety
// channelMap.get() returns Java objects in Rhino; String() forces primitive JS types.
// ===========================================================================
var isAmendment = String(channelMap.get(&apos;isAmendment&apos;)) === &apos;true&apos;;
var csn         = channelMap.get(&apos;csn&apos;);
var noteText    = channelMap.get(&apos;noteText&apos;);
var versionRaw  = channelMap.get(&apos;versionNum&apos;);
var reason      = channelMap.get(&apos;amendmentReason&apos;);
var authoredBy  = channelMap.get(&apos;authoredBy&apos;);

// Escape single quotes to protect against SQL parsing syntax errors
var safeCsn    = csn      ? String(csn).replace(/&apos;/g, &quot;&apos;&apos;&quot;)      : &quot;&quot;;
var safeNote   = noteText ? String(noteText).replace(/&apos;/g, &quot;&apos;&apos;&quot;) : &quot;&quot;;
var safeReason = reason   ? String(reason).replace(/&apos;/g, &quot;&apos;&apos;&quot;)   : &quot;&quot;;
var versionNum = versionRaw ? parseInt(String(versionRaw)) : 1;

// Strip non-numeric characters to protect unquoted integer SQL injection vectors
var safeAuthor = (authoredBy &amp;&amp; String(authoredBy).trim() !== &apos;&apos; &amp;&amp; String(authoredBy) !== &apos;NULL&apos;)
                 ? String(authoredBy).replace(/[^0-9]/g, &apos;&apos;)
                 : &apos;NULL&apos;;

// ===========================================================================
// STEP 2: Manage Connection Lifecycle and Execute Conditional Routing
// Business logic lives inside the try block so it runs while the pool connection is alive.
// ===========================================================================
var dbConn;

try {
    // Open the manual PostgreSQL connection channel
    dbConn = DatabaseConnectionFactory.createDatabaseConnection(
        &apos;org.postgresql.Driver&apos;,
        &apos;jdbc:postgresql://localhost:5432/simulated_emr&apos;,
        &apos;postgres&apos;,
        &apos;devpassword&apos;
    );

    if (isAmendment) {
        // 1. Mark all prior versions for this CSN as no longer current
        dbConn.executeUpdate(
            &quot;UPDATE clinical_note_versions SET is_current = FALSE WHERE csn = &apos;&quot; + safeCsn + &quot;&apos;&quot;
        );

        // 2. Insert the new amendment version row
        dbConn.executeUpdate(
            &quot;INSERT INTO clinical_note_versions &quot; +
            &quot;(csn, note_text, version_num, is_current, authored_by, amendment_reason, status, date_signed) &quot; +
            &quot;VALUES (&apos;&quot; + safeCsn + &quot;&apos;, &apos;&quot; + safeNote + &quot;&apos;, &quot; + versionNum + &quot;, TRUE, &quot; +
            safeAuthor + &quot;, &apos;&quot; + safeReason + &quot;&apos;, &apos;SIGNED&apos;, NOW())&quot;
        );

        logger.info(&apos;[aiscribe-inbound] Amendment v&apos; + versionNum + &apos; written — CSN: &apos; + safeCsn);

    } else {
        // Initial note — original upsert behavior
        dbConn.executeUpdate(
            &quot;INSERT INTO clinical_notes (csn, note_text, status, date_signed) &quot; +
            &quot;VALUES (&apos;&quot; + safeCsn + &quot;&apos;, &apos;&quot; + safeNote + &quot;&apos;, &apos;SIGNED&apos;, NOW()) &quot; +
            &quot;ON CONFLICT (csn) DO UPDATE SET &quot; +
            &quot;note_text = EXCLUDED.note_text, status = &apos;SIGNED&apos;, date_signed = NOW()&quot;
        );

        logger.info(&apos;[aiscribe-inbound] Initial note written — CSN: &apos; + safeCsn);
    }

} catch (e) {
    logger.error(&apos;[aiscribe-inbound] DATABASE TRANSACT FAILURE: &apos; + e.message);
    throw e; // Rethrowing forces Mirth to flag the message as &quot;Errored&quot; on the dashboard

} finally {
    // The finally block guarantees the connection closes, preventing leaks even if SQL crashes
    if (dbConn) { 
        dbConn.close(); 
    }
}</query>
