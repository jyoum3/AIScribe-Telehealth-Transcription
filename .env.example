# =============================================================================
# AIScribe — Environment Variable Template
#
# Copy this file to .env.local in the project root and fill in real values.
# .env.local is listed in .gitignore and MUST NEVER be committed.
#
# The Express API reads from .env.local via dotenv at startup.
# =============================================================================

# Frontend
FRONTEND_ORIGIN=http://localhost:3000

# Backend
EXPRESS_PORT=3001
NODE_ENV=development

# JWT — Token signing secret
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this

# Database: aiscribe_app (provider auth, audit logs, idempotency)
AISCRIBE_APP_DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/aiscribe_app
AISCRIBE_APP_DB_USER=postgres
AISCRIBE_APP_DB_PASSWORD=devpassword
AISCRIBE_APP_DB_HOST=localhost
AISCRIBE_APP_DB_PORT=5432
AISCRIBE_APP_DB_NAME=aiscribe_app

# Database: simulated_emr (patient data, encounters, clinical notes)
SIMULATED_EMR_DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/simulated_emr
SIMULATED_EMR_DB_USER=postgres
SIMULATED_EMR_DB_PASSWORD=devpassword
SIMULATED_EMR_DB_HOST=localhost
SIMULATED_EMR_DB_PORT=5432
SIMULATED_EMR_DB_NAME=simulated_emr

POSTGRES_SSL_MODE=prefer

# Mirth Connect — HTTP listener for note submission
# Port 8081 is the AIScribe inbound channel listener.
MIRTH_HTTP_LISTENER_URL=http://localhost:8081/aiscribe-inbound/
MIRTH_HOST=localhost
MIRTH_PORT=8081

# External AI APIs
# OpenAI:    https://platform.openai.com/account/api-keys
# Anthropic: https://console.anthropic.com/account/keys
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# Logging
LOG_LEVEL=debug
DEBUG=aiscribe:*
