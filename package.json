{
  "name": "aiscribe",
  "version": "1.0.0",
  "private": true,
  "description": "AIScribe Telehealth Transcription — AI-powered psychiatric SOAP note generation with HL7 v2 EHR integration",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "api": "npm run dev --workspace=apps/api",
    "web": "npm run dev --workspace=apps/web",
    "dev": "concurrently \"npm run api\" \"npm run web\"",
    "install:all": "npm install",
    "seed:clinical": "node apps/api/scripts/seedClinicalData.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
